# Compose files to load (colon-separated, merged left to right).
# COMPOSE_FILE=compose.yaml
# COMPOSE_FILE=compose.yaml:compose.dev.yaml
# COMPOSE_FILE=compose.yaml:compose.watchtower.yaml

# Container user identity — match your host user to avoid
# file ownership issues on bind mounts. Defaults to 1000.
PUID=1000
PGID=1000

# Optional: OpenZiti overlay
ZITI_IDENTITY=
ZITI_SERVICE=

# Optional: ACME TLS (all three required to enable)
DNS_SAN=
CLOUDFLARE_API_KEY=
TLS_PRIVKEY=
